---
import ProfileImage from './profileImage.astro';
import Socials from './Socials.astro';
import SocialIconWrapper from './SocialIconWrapper';
import { FaSkull } from 'react-icons/fa';
---

<div>
  <div class='flex flex-col sm:flex-row items-center sm:items-start space-y-4 sm:space-y-0 sm:space-x-6 text-center sm:text-left'>
    <ProfileImage size='large' />
    <div class='flex-1'>
      <h1 class='text-2xl sm:text-3xl md:text-4xl font-bold text-white uppercase tracking-wide flex items-center justify-center sm:justify-start gap-2 sm:gap-3 flex-wrap'>
        Anton <span class="text-xl sm:text-2xl md:text-3xl"><SocialIconWrapper client:visible Icon={FaSkull} className="text-white inline-block"/></span>
      </h1>
      <h2 class='align-middle text-base sm:text-lg leading-6 text-gray-400 uppercase tracking-wider mt-2'>
        Network Engineer | DJ
      </h2>
    </div>
  </div>
  <article class='mt-6 sm:mt-9 text-lg sm:text-xl text-gray-200 leading-relaxed'>
    I'm <span id='age'></span>, building stuff with <strong class='font-bold text-red-400 border-b-2 border-red-400/60'>Perl</strong> & <strong class='font-bold text-blue-400 border-b-2 border-blue-400/60'>TypeScript</strong>. 
    Coding web apps, spinning <strong class='font-bold text-pink-400 border-b-2 border-pink-400/60'>hyperpop</strong> & <strong class='font-bold text-purple-400 border-b-2 border-purple-400/60'>dubstep</strong> sets at underground spots, and making things with 3D printing. If it's creative or breaks the mold, I'm into it.
  </article>
  <div class='mt-9'>
    <Socials />
  </div>
</div>

<script>
  import { getYearDiffFromDate } from '../utils/getYearDiffFromDate';

  const ageElement = document.getElementById('age');
  ageElement!.innerText = getYearDiffFromDate('05/27/2005').toString();
</script>