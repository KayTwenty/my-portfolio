---
import { Transition } from "./Transition";
import ProfileImage from "./profileImage.astro";

interface Props {
  showNav?: boolean;
  navRefId: string;
}

const { showNav, navRefId } = Astro.props;
---

<div class="pointer-events-none fixed inset-x-0 top-0 z-30 flex justify-center px-3 sm:px-6 transition-all duration-300" id="navbar-container">
  <nav class="pointer-events-auto inline-flex items-center rounded-none bg-black/90 backdrop-blur-sm border-2 border-white/20 shadow-2xl shadow-black transition-all duration-300 hover:border-white/40 hover:shadow-red-900/20 max-w-full" id="navbar">
    <ProfileImage size="small" />
    <a href="#skills" class="text-gray-300 hover:text-white transition-colors font-medium nav-link uppercase whitespace-nowrap">Skills</a>
    <a href="#showcase" class="text-gray-300 hover:text-white transition-colors font-medium nav-link uppercase whitespace-nowrap">Showcase</a>
    <span class="text-gray-600 cursor-not-allowed font-medium transition-all duration-300 uppercase whitespace-nowrap" title="Coming soon" id="blog-text">Blog</span>
  </nav>
</div>

<script>
  let lastScrollY = window.scrollY;
  const navbar = document.getElementById('navbar');
  const blogText = document.getElementById('blog-text');
  const navLinks = document.querySelectorAll('.nav-link');

  // Initialize navbar size based on screen width and scroll position
  function updateNavbar() {
    const currentScrollY = window.scrollY;
    const isMobile = window.innerWidth < 640;
    
    if (isMobile) {
      // Mobile: always small
      navbar?.classList.add('px-3', 'py-2', 'gap-3', 'mt-3');
      navbar?.classList.remove('px-4', 'px-6', 'py-3', 'gap-4', 'gap-6', 'mt-6');
      blogText?.classList.add('text-sm');
      blogText?.classList.remove('text-lg');
      navLinks.forEach(link => {
        link.classList.add('text-sm', 'tracking-wide');
        link.classList.remove('text-lg', 'tracking-wider');
      });
    } else if (currentScrollY > 100) {
      // Desktop scrolled: small
      navbar?.classList.add('px-4', 'py-2', 'gap-4', 'mt-3');
      navbar?.classList.remove('px-3', 'px-6', 'py-3', 'gap-3', 'gap-6', 'mt-6');
      blogText?.classList.add('text-sm');
      blogText?.classList.remove('text-lg');
      navLinks.forEach(link => {
        link.classList.add('text-sm');
        link.classList.remove('text-lg');
      });
    } else {
      // Desktop at top: large
      navbar?.classList.add('px-6', 'py-3', 'gap-6', 'mt-6');
      navbar?.classList.remove('px-3', 'px-4', 'py-2', 'gap-3', 'gap-4', 'mt-3');
      blogText?.classList.add('text-lg');
      blogText?.classList.remove('text-sm');
      navLinks.forEach(link => {
        link.classList.add('text-lg', 'tracking-wider');
        link.classList.remove('text-sm', 'tracking-wide');
      });
    }
  }

  // Run on load
  updateNavbar();

  // Run on scroll
  window.addEventListener('scroll', updateNavbar);

  // Run on resize
  window.addEventListener('resize', updateNavbar);
</script>