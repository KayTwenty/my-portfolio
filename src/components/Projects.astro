---
import { projects } from "../data/projects";
import Card from "./Card.astro";
---

<div class="mt-12 sm:mt-16">
  <h2 class="text-xl sm:text-2xl md:text-3xl font-bold text-white uppercase tracking-widest border-b-4 border-white/30 pb-2 sm:pb-3">Projects</h2>
  <p class="mt-5 sm:mt-7 text-lg sm:text-xl text-gray-300">
    I"ve build many projects using different technologies. Here are some of my
    notable works.
  </p>
  <div class="mt-9 mb-7 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {
      projects.map((project) => (
        <Card
          image={project.image}
          title={project.title}
          link={project.link}
          substring={project.stack.trim().split(",").join(" · ")}
          description={project.description}
        />
      ))
    }
  </div>
  <a
    href="https://github.com/KayTwenty?tab=repositories"
    class="inline-block text-lg sm:text-xl text-gray-300 font-bold hover:text-white hover:underline underline-offset-4 focus:outline-none focus-visible:ring-2 focus-visible:ring-white uppercase tracking-wider min-h-11 py-2"
  >
    View more projects
  </a>
</div>