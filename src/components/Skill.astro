---
interface Props {
  icon: string;
  title: string;
  link: string;
}

const { icon, title, link } = Astro.props;
---

<a href={link} target="_blank" class="min-h-11 block">
  <div
    class="cursor-pointer flex items-center overflow-hidden bg-black border-2 border-white/30 py-3 sm:py-4 px-2 sm:px-3 shadow-2xl transition duration-300 hover:border-white hover:bg-white/5"
  >
    <img src={icon + "&color=fff"} alt={title} class="w-6 sm:w-7 shrink-0" />
    <p class="ml-2 text-sm sm:text-base md:text-lg text-white font-bold uppercase tracking-wide truncate">{title}</p>
  </div>
</a>