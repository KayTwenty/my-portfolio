---
import SocialIcon from "./socialIcon.astro";
import SocialIconWrapper from "./SocialIconWrapper";
import { FaGithub, FaLinkedin, FaEnvelope, FaDiscord } from "react-icons/fa";
---

<div class="flex flex-wrap gap-3 sm:gap-4 text-sm sm:text-base font-medium leading-none text-gray-300 justify-center sm:justify-start">
  <SocialIcon
    Icon={FaGithub}
    title="GitHub"
    link="https://github.com/KayTwenty"
  />
  <SocialIcon
    Icon={FaDiscord}
    title="Discord"
    link="https://discord.com/users/751172060289433695"
  />
  <button
    id="email-button"
    class="group flex items-center space-x-2 sm:space-x-3 bg-black border-2 border-white/40 px-3 sm:px-4 py-2 sm:py-2.5 transition-all duration-300 hover:scale-105 sm:hover:scale-[1.2] hover:border-white hover:shadow-lg hover:shadow-red-900/40 focus:outline-none focus-visible:ring-2 focus-visible:ring-white uppercase tracking-wider min-h-11"
  >
    <div class="text-white text-lg sm:text-xl md:text-2xl">
      <SocialIconWrapper client:visible Icon={FaEnvelope} className="text-white"/>
    </div>
    <span class="text-gray-300 group-hover:text-white text-xs sm:text-sm">Email</span>
  </button>
  <!-- <SocialIcon
    Icon={FaLinkedin}
    title="LinkedIn"
    link="https://www.linkedin.com/in/davidantonn/"
  /> -->
</div>

<!-- Email Modal -->
<div id="email-modal" class="hidden fixed inset-0 z-50 bg-black/95 backdrop-blur-sm">
  <div class="h-full flex items-center justify-center p-4 sm:p-6">
    <div class="bg-black border-4 border-white/40 p-4 sm:p-6 md:p-8 max-w-md w-full">
      <div class="flex items-center justify-between mb-4 sm:mb-6">
        <h3 class="text-xl sm:text-2xl font-bold text-white uppercase tracking-wide">Contact Me</h3>
        <button
          id="close-email-modal"
          class="text-white text-3xl sm:text-4xl hover:text-red-500 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-white min-w-11 min-h-11 flex items-center justify-center"
          aria-label="Close modal"
        >
          ×
        </button>
      </div>
      
      <!-- Math Challenge -->
      <div id="math-challenge" class="text-gray-300 text-base sm:text-lg leading-relaxed space-y-3 sm:space-y-4">
        <p>Solve this to prove you're human:</p>
        <div class="bg-white/5 border-2 border-white/20 p-4 text-center">
          <p class="text-white text-2xl sm:text-3xl font-bold mb-4" id="math-question"></p>
          <input
            type="number"
            id="math-answer"
            class="w-full bg-black border-2 border-white/40 text-white text-center text-xl sm:text-2xl p-3 focus:outline-none focus:border-white"
            placeholder="?"
          />
        </div>
        <button
          id="submit-math"
          class="w-full bg-white/10 border-2 border-white/30 px-4 py-3 text-white hover:bg-white/20 hover:border-white transition-all uppercase tracking-wider font-bold"
        >
          Submit
        </button>
        <p id="math-error" class="text-red-400 text-sm text-center hidden">Incorrect answer. Try again!</p>
      </div>

      <!-- Email Construction (Hidden Initially) -->
      <div id="email-construction" class="hidden text-gray-300 text-base sm:text-lg leading-relaxed space-y-3 sm:space-y-4">
        <p>To prevent spam bots, construct my email:</p>
        <div class="bg-white/5 border-2 border-white/20 p-3 sm:p-4 font-mono text-white text-sm sm:text-base break-all">
          <span class="text-red-400">davidanton037</span>
          <span class="text-gray-400"> + </span>
          <span class="text-red-400">@</span>
          <span class="text-gray-400"> + </span>
          <span class="text-red-400">gmail</span>
          <span class="text-gray-400"> DOT </span>
          <span class="text-red-400">com</span>
        </div>
        <p class="text-xs sm:text-sm text-gray-400">Copy and paste the parts to form the email address.</p>
      </div>
    </div>
  </div>
</div>

<script>
  const emailButton = document.getElementById('email-button');
  const emailModal = document.getElementById('email-modal');
  const closeEmailModalButton = document.getElementById('close-email-modal');
  const mathChallenge = document.getElementById('math-challenge');
  const emailConstruction = document.getElementById('email-construction');
  const mathQuestion = document.getElementById('math-question');
  const mathAnswerInput = document.getElementById('math-answer') as HTMLInputElement;
  const submitMathButton = document.getElementById('submit-math');
  const mathError = document.getElementById('math-error');

  let correctAnswer = 0;

  function generateMathProblem() {
    const operations = ['×', '÷'];
    const operation = operations[Math.floor(Math.random() * operations.length)];
    
    let num1: number, num2: number;
    
    if (operation === '÷') {
      // For division, ensure clean division with no remainders
      num2 = Math.floor(Math.random() * 10) + 2; // divisor: 2-11
      const quotient = Math.floor(Math.random() * 10) + 2; // result: 2-11
      num1 = num2 * quotient; // dividend
      correctAnswer = quotient;
    } else {
      // Multiplication with reasonable numbers
      num1 = Math.floor(Math.random() * 12) + 2; // 2-13
      num2 = Math.floor(Math.random() * 12) + 2; // 2-13
      correctAnswer = num1 * num2;
    }
    
    mathQuestion!.textContent = `${num1} ${operation} ${num2} = ?`;
  }

  emailButton?.addEventListener('click', () => {
    // Reset modal state
    mathChallenge?.classList.remove('hidden');
    emailConstruction?.classList.add('hidden');
    mathError?.classList.add('hidden');
    if (mathAnswerInput) mathAnswerInput.value = '';
    
    // Generate new math problem
    generateMathProblem();
    
    emailModal?.classList.remove('hidden');
    
    // Focus on input
    setTimeout(() => mathAnswerInput?.focus(), 100);
  });

  closeEmailModalButton?.addEventListener('click', () => {
    emailModal?.classList.add('hidden');
  });

  submitMathButton?.addEventListener('click', () => {
    const userAnswer = parseInt(mathAnswerInput?.value || '0');
    
    if (userAnswer === correctAnswer) {
      mathChallenge?.classList.add('hidden');
      emailConstruction?.classList.remove('hidden');
      mathError?.classList.add('hidden');
    } else {
      mathError?.classList.remove('hidden');
      if (mathAnswerInput) mathAnswerInput.value = '';
      mathAnswerInput?.focus();
    }
  });

  // Allow Enter key to submit
  mathAnswerInput?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      submitMathButton?.click();
    }
  });

  // Close modal on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      emailModal?.classList.add('hidden');
    }
  });

  // Close modal when clicking outside
  emailModal?.addEventListener('click', (e) => {
    if (e.target === emailModal) {
      emailModal.classList.add('hidden');
    }
  });
</script>