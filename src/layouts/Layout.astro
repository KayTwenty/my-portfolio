---
import '../styles/global.css';

interface Props {
  showNav?: boolean;
  navRefId: string;
}

const { showNav, navRefId } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Explore the innovative projects and skills of Anton (Kay), a full stack developer and systems administrator proficient in Perl, TypeScript, and web development. View my work!">
    <meta name="keywords" content="Full Stack Developer, Systems Administrator, Perl, TypeScript, Web Development, Indie Games, 3D Printing, Resin Printing, Innovative Projects">
    <title id="page-title">Anton - Full Stack Developer & Systems Administrator</title>

    <!-- Favicon -->
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
    <link rel="manifest" href="/favicon/site.webmanifest">
    <meta name="msapplication-TileColor" content="#da532c">

    <!-- Twitter Card -->
    <meta name="twitter:title" content="Anton - Full Stack Developer & Systems Administrator">
    <meta name="twitter:description" content="Explore the innovative projects and skills of Anton (Kay), a full stack developer and systems administrator proficient in Perl, TypeScript, and web development.">
    <meta name="twitter:image" content="/icon.jpg">

    <!-- Open Graph -->
    <meta property="og:title" content="Anton - Full Stack Developer & Systems Administrator">
    <meta property="og:description" content="Explore the innovative projects and skills of Anton (Kay), a full stack developer and systems administrator proficient in Perl, TypeScript, and web development.">
    <meta property="og:image" content="/icon.jpg">
    <meta property="og:url" content="https://kaytwenty.com">
    <meta property="og:url" content="https://antton.ca">
    <meta property="og:type" content="website">

    <!-- Schema.org -->
    <script type="application/ld+json">
        {
          "@context": "http://schema.org",
          "@type": "Person",
          "name": "David Anton",
          "alternateName": ["Kay", "Anton"],
          "jobTitle": "Full Stack Developer & Systems Administrator",
          "email": "davidanton037@gmail.com",
          "url": ["https://kaytwenty.com", "https://antton.ca"]
        }
    </script>
  </head>
  <body style="margin: 0; padding: 0; background: white; color: black;">
    <slot />
    <script>
      // Set title based on domain
      const hostname = window.location.hostname;
      const titleElement = document.getElementById('page-title');
      
      if (hostname.includes('kaytwenty.com')) {
        document.title = 'Kay - Full Stack Developer & Systems Administrator';
      } else if (hostname.includes('antton.ca')) {
        document.title = 'David Anton - Full Stack Developer & Systems Administrator';
      } else {
        document.title = 'Anton - Full Stack Developer & Systems Administrator';
      }
    </script>
  </body>
</html>